# Open Researcher Environment Variables
# Copy this file to .env.local and fill in your actual API keys

# AI Provider Configuration (choose one or configure both)
# ========================================================

# Option 1: Anthropic Claude (Current default)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: Azure OpenAI (Alternative provider)
# Get yours from Azure Portal OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here

# AI Provider Selection (anthropic or azure)
# If not set, will auto-detect based on available API keys
AI_PROVIDER=anthropic

# Web Scraping Configuration
# ==========================

# Optional: Firecrawl API key for web scraping
# If not provided, you can add it through the UI
# Get yours at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
